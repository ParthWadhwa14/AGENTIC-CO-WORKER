QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=personal_workspace_chunks
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
GROQ_API_KEY=
GENERATION_MODEL=openai/gpt-oss-120b
FALLBACK_GENERATION_MODEL=openai/gpt-oss-20b
GENERATION_TEMPERATURE=0.2
GROQ_CONTEXT_CHAR_LIMIT=70000
GROQ_MAX_OUTPUT_TOKENS=4096

# Local MVP metadata DB. PostgreSQL schema is in db/schema.sql.
DATABASE_URL=sqlite:///ingestion/app.db
METADATA_DATABASE_URL=sqlite:///ingestion/app.db

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_UPLOAD_BUCKET=user-uploads

UPLOAD_DIR=ingestion/uploaded_files
DRIVE_DOWNLOAD_DIR=ingestion/synced_drive_files

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Use GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET, or use a downloaded client JSON.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_SECRETS_FILE=
GOOGLE_CLIENT_CONFIG_JSON=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Production Railway value:
# GOOGLE_REDIRECT_URI=https://agentic-co-worker-production.up.railway.app/auth/google/callback
# Production Railway value: https://agentic-co-worker.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional overrides. Defaults already include these values.
GOOGLE_BASE_SCOPES=openid email profile
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.metadata.readonly https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/documents.readonly https://www.googleapis.com/auth/spreadsheets.readonly
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Use this only for local OAuth testing if oauthlib rejects localhost HTTP.
# OAUTHLIB_INSECURE_TRANSPORT=1
